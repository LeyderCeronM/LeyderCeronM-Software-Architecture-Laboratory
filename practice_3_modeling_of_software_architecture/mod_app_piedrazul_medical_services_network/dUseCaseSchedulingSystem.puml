@startuml SistemaAgendamientoUseCases
left to right direction

actor Paciente
actor Medico
actor Agendador
actor Administrador

rectangle "Sistema de Agendamiento de Citas Médicas" {

    usecase "Agendar Cita" as UC1
    usecase "Cancelar Cita" as UC2
    usecase "Reprogramar Cita" as UC3
    usecase "Consultar Agenda" as UC4
    usecase "Registrar Historia Clínica" as UC5
    usecase "Consultar Historia Clínica" as UC6
    usecase "Registrar Usuario" as UC7
    usecase "Gestionar Usuarios" as UC8
}

Paciente --> UC1
Paciente --> UC2
Paciente --> UC4

Agendador --> UC1
Agendador --> UC2
Agendador --> UC3
Agendador --> UC4

Medico --> UC4
Medico --> UC5
Medico --> UC6

Administrador --> UC7
Administrador --> UC8

@enduml