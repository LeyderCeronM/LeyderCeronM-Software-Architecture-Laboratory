@startuml AgendarCitaSequence

actor Usuario

participant "AgendarCitaView\n(Presentación)" as View
participant "AgendarCitaController\n(Presentación)" as Controller
participant "CitaService\n(Aplicación)" as Service
participant "Cita\n(Dominio)" as Cita
participant "CitaRepository\n(Infraestructura)" as Repository
database "SQLite DB" as DB

Usuario -> View : Completa formulario\n(paciente, medico, fecha, hora)

View -> Controller : solicitarAgendamiento(datos)

Controller -> Service : agendarCita(datos)

Service -> Cita : crearCita(datos)
Cita -> Cita : validarReglas()\n- Fecha futura\n- No solapamiento

Service -> Repository : verificarDisponibilidad(medico, fecha, hora)
Repository -> DB : SELECT disponibilidad
DB --> Repository : resultado
Repository --> Service : disponible / no disponible

alt Disponible
    Service -> Repository : guardar(cita)
    Repository -> DB : INSERT cita
    DB --> Repository : OK
    Repository --> Service : confirmación
    
    Service --> Controller : éxito
    Controller --> View : mostrarConfirmación()
else No disponible
    Service --> Controller : errorDisponibilidad
    Controller --> View : mostrarError()
end

@enduml